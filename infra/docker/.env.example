# Copy to infra/docker/.env for `docker compose up`.
# NOTE (gotcha 1 / invariant 11): the shell exports POSTGRES_*/DATABASE_URL and
# Compose resolves ${VAR} from the shell before this file. Use the `env -u ...`
# workaround documented at the top of docker-compose.yml when bringing the
# stack up. See infra/docker/README.md.

# --- Postgres (interpolated into ${VAR} in docker-compose.yml) ---
POSTGRES_DB=searchify
POSTGRES_USER=postgres
POSTGRES_PASSWORD=searchify_dev_password

# --- Backend app settings (injected into the container via env_file) ---
APP_ENV=development
# DATABASE_URL is derived in compose from POSTGRES_* against the db service.
JWT_SECRET_KEY=replace-with-a-64-byte-random-secret-for-local-dev-only-000000
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
ENCRYPTION_KEY=replace-with-a-32-byte-min-random-secret-local-dev-only
FRONTEND_URL=http://127.0.0.1:3000
FRONTEND_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# --- Optional observability ---
LOGFIRE_ENABLED=false
LOGFIRE_TOKEN=

# --- Default agent (assisted features: prompt generation, future content) ---
# OpenAI-compatible chat/completions endpoint. MISTRALAI_API_KEY is accepted
# as a legacy alias for DEFAULT_AGENT_API_KEY.
DEFAULT_AGENT_API_KEY=
DEFAULT_AGENT_BASE_URL=https://api.mistral.ai/v1
DEFAULT_AGENT_MODEL=mistral-small-latest
GENERATION_DEFAULT_COUNT=10
GENERATION_MAX_COUNT=20

